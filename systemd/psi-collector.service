[Unit]
Description=Observability Platform - PSI Collector
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=observer
Group=observer
Environment="DB_DSN=dbname=observability user=observer password=observer host=127.0.0.1"
Environment="PGPASSWORD=observer"
ExecStart=/usr/local/bin/psi_collector.sh
StandardOutput=journal
StandardError=journal
